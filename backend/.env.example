# Copy to backend/.env and fill in. Restart the backend after editing.
#
# The agents always construct AsyncOpenAI() with NO arguments — the SDK
# auto-resolves the endpoint + auth from these standard env vars. Inside
# Capital One's COF proxy environment, none of these need to be set: the
# corporate openai SDK fork preconfigures the proxy transparently.
#
# Outside the corporate environment, set:
#   OPENAI_API_KEY  — your direct-OpenAI key (sk-...)
# Optionally set:
#   OPENAI_BASE_URL — alternate endpoint (e.g. an internal gateway)
#
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Optional: override which model the tool/analytics drafter uses
# (skill .md files each declare their own model; this only affects the
# direct-OpenAI drafter endpoints in routers/tools.py + analytics_defs.py).
# CMA_TOOL_DRAFT_MODEL=gpt-oss-120b
