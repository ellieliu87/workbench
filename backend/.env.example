# Copy to backend/.env and fill in. Restart the backend after editing.
#
# Pick ONE of the following:
#
# (A) Capital One internal LLM (no key needed)
# COF_BASE_URL=https://your-internal-endpoint/v1
# COF_API_KEY=optional-bearer-if-required
#
# (B) Direct OpenAI
OPENAI_API_KEY=sk-...

# Optional: override which model every skill uses (defaults to whatever the
# skill .md file declares — currently gpt-4o).
# CMA_DEFAULT_MODEL=gpt-4o
