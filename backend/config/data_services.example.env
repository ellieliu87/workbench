# Data Services integration knobs.
#
# Copy these into the backend's runtime env (e.g. `.env`, systemd unit,
# Kubernetes Secret) when running inside the corporate proxy environment.
# All flags default to OFF, so the app works end-to-end as a static demo
# without any of these set.
#
# Behavior summary:
#   - Each integration is independently switchable.
#   - When an integration is enabled but fails at runtime (package not
#     installed, OneLake unreachable, schema drift), the backend logs a
#     warning and falls back to the static specs in
#     `backend/services/data_services.py` so the UI keeps working.
#   - The frontend renders an integration-status badge on each section
#     so the analyst can see live vs. fallback at a glance.
# ---------------------------------------------------------------------

# ── Predictive Analytics tools (Data Harness + Data Quality Check) ────
# When enabled, the backend imports the configured pip package and
# discovers its `DataHarness` / `DataQualityCheck` entries by name
# convention. Title, description, and any class metadata are pulled from
# the package's own attributes so updating the cards is a `pip install
# --upgrade` away — no app deploy needed.

CMA_PA_COMMON_TOOLS_ENABLED=1
CMA_PA_COMMON_TOOLS_PACKAGE=pa_common_tools

# ── OneLake-backed CCAR + Outlook scenarios ──────────────────────────
# When enabled, CCAR and Outlook cards come from the configured OneLake
# tables instead of the static templates. The actual extractor lives in
# `backend/services/data_services.py:_onelake_read_table` — replace the
# stub there with your corporate extractor (the file's docstring shows
# the recipe). Every other knob in this section is just routing data
# *into* that extractor.

CMA_ONELAKE_SCENARIOS_ENABLED=1
CMA_ONELAKE_WORKSPACE=Finance
CMA_ONELAKE_LAKEHOUSE=cma
CMA_ONELAKE_CCAR_TABLE=ccar_scenarios
CMA_ONELAKE_OUTLOOK_TABLE=outlook_scenarios

# Expected column shapes (the loader reads these field names):
#   ccar_scenarios:    year, code, label, severity, source, description
#   outlook_scenarios: id, title, subtitle, description
#                      [optional: color, icon, tag, agent_prompt]
